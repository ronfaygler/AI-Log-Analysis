# MongoDB
MONGO_ROOT_USERNAME=logsentinel
MONGO_ROOT_PASSWORD=changeme
MONGO_DATABASE=logsentinel

# Redis
REDIS_PASSWORD=changeme

# JWT & API
JWT_SECRET=changeme-generate-a-long-random-string
JWT_EXPIRES_IN=7d
API_KEY_SALT=changeme
